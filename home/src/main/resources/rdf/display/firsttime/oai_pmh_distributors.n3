:2c68f9ee-4a4c-444c-b6fc-a14a7759b235
        a                       <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.ConstructQueryGraphBuilder> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.GraphBuilder> ;
        vitro:mostSpecificType  <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.ConstructQueryGraphBuilder> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.GraphBuilder> ;
        :builderName            "OAI PMH Product" ;
        :constructQuery         "PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\r\nPREFIX bibo: <http://purl.org/ontology/bibo/>\r\nPREFIX vitro: <http://vitro.mannlib.cornell.edu/ns/vitro/0.7#>\r\nPREFIX bib: <http://zeitkunst.org/bibtex/0.1/bibtex.owl#>\r\nPREFIX vivo: <http://vivoweb.org/ontology/core#>\r\nPREFIX foaf: <http://xmlns.com/foaf/0.1/>\r\nPREFIX ev: <http://www.w3.org/2001/xml-events/>\r\nPREFIX event: <http://purl.org/NET/c4dm/event.owl#>\r\nPREFIX obo: <http://purl.obolibrary.org/obo/>\r\nPREFIX vcard: <http://www.w3.org/2006/vcard/ns#>\r\nCONSTRUCT {\r\n  ?product rdfs:comment \"OpenAIRE Product\" .\r\n  ?product ?productP ?productO .\r\n  ?product vivo:hasSubjectArea ?concept .\r\n  ?concept rdfs:label ?conceptLabel .\r\n  ?product ?publicationToEventProp ?event .\r\n  ?event ?eventProp ?eventValue .\r\n  ?product vivo:relatedBy ?relBy .\r\n  ?relBy a ?relType .\r\n  ?relBy vivo:relates ?agent .\r\n  ?agent a ?agentType .\r\n  ?agent rdfs:label ?agentLabel .\r\n  ?product obo:ARG_2000028 ?kind .\r\n  ?kind vcard:hasURL ?vcardURL .\r\n  ?vcardURL vcard:url ?url .\r\n} WHERE {\r\n  BIND (?uri as ?product)\r\n  {\r\n    ?product a bibo:AudioVisualDocument .\r\n  }\r\n  UNION\r\n  {\r\n    ?product a vivo:CaseStudy .\r\n  }\r\n  UNION\r\n  {\r\n    ?product a vivo:Dataset .\r\n  }\r\n  UNION\r\n  {\r\n    ?product a bibo:Image .\r\n  }\r\n  ?product rdfs:label|vitro:mostSpecificType|a|bibo:doi|vivo:freetextKeyword|bibo:abstract ?o .\r\n  ?product ?productP ?productO .\r\n  OPTIONAL {\r\n    ?product vivo:hasSubjectArea ?concept .\r\n    ?concept rdfs:label ?conceptLabel .\r\n  }\r\n  OPTIONAL {\r\n    ?product bibo:presentedAt|obo:RO_0002353 ?event .\r\n    ?product ?publicationToEventProp ?event .\r\n    ?event a|rdfs:label|vivo:abbreviation ?eventValue .\r\n    ?event ?eventProp ?eventValue .\r\n  }\r\n  OPTIONAL {\r\n    ?product vivo:relatedBy ?relBy .\r\n    ?relBy a ?relType .\r\n    ?relBy vivo:relates ?agent .\r\n    ?agent a ?agentType .\r\n    ?agent rdfs:label ?agentLabel .\r\n  }\r\n  OPTIONAL {\r\n    ?product obo:ARG_2000028 ?kind .\r\n    ?kind vcard:hasURL ?vcardURL .\r\n    ?vcardURL vcard:url ?url .\r\n  }\r\n}" ;
        :uriBinding             "uri" .

:c8de5b6c-db9e-40c1-8687-5627c76f85ce
        a                       <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.ConstructQueryGraphBuilder> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.GraphBuilder> ;
        vitro:mostSpecificType  <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.ConstructQueryGraphBuilder> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.GraphBuilder> ;
        :builderName            "OAI PMH Patent" ;
        :constructQuery         "PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\r\nPREFIX bibo: <http://purl.org/ontology/bibo/>\r\nPREFIX vitro: <http://vitro.mannlib.cornell.edu/ns/vitro/0.7#>\r\nPREFIX bib: <http://zeitkunst.org/bibtex/0.1/bibtex.owl#>\r\nPREFIX vivo: <http://vivoweb.org/ontology/core#>\r\nPREFIX foaf: <http://xmlns.com/foaf/0.1/>\r\nPREFIX ev: <http://www.w3.org/2001/xml-events/>\r\nPREFIX event: <http://purl.org/NET/c4dm/event.owl#>\r\nPREFIX vcard: <http://www.w3.org/2006/vcard/ns#>\r\nPREFIX obo: <http://purl.obolibrary.org/obo/>\r\nCONSTRUCT {\r\n  ?patent rdfs:comment \"OpenAIRE Patent\" .\r\n  ?patent ?p ?o .\r\n  ?patent vivo:relatedBy ?relBy .\r\n  ?relBy a ?relType .\r\n  ?relBy vivo:relates ?agent .\r\n  ?agent a ?agentType .\r\n  ?agent rdfs:label ?agentLabel .\r\n  ?patent obo:ARG_2000028 ?kind .\r\n  ?kind vcard:hasURL ?vcardURL .\r\n  ?vcardURL vcard:url ?url .\r\n  ?patent vivo:hasSubjectArea ?area .\r\n  ?area ?areaP ?areaO .\r\n  ?publication vivo:dateIssued ?dateIssued .\r\n  ?dateIssued ?dateIssuedP ?dateIssuedO .\r\n  ?publication vivo:dateFiled ?dateFiled .\r\n  ?dateFiled ?dateFiledP ?dateFiledO .\r\n} WHERE {\r\n  BIND (?uri as ?patent)\r\n  ?patent a bibo:Patent .\r\n  ?patent rdfs:label|vitro:mostSpecificType|a|vivo:freetextKeyword|bibo:abstract|vivo:patentNumber ?o .\r\n  ?patent ?p ?o .\r\n  OPTIONAL {\r\n    ?patent vivo:relatedBy ?relBy .\r\n    ?relBy a ?relType .\r\n    ?relBy vivo:relates ?agent .\r\n    ?agent a ?agentType .\r\n    ?agent rdfs:label ?agentLabel .\r\n  }\r\n  OPTIONAL {\r\n    ?patent obo:ARG_2000028 ?kind .\r\n    ?kind vcard:hasURL ?vcardURL .\r\n    ?vcardURL vcard:url ?url .\r\n  }\r\n  OPTIONAL {\r\n    ?patent vivo:hasSubjectArea ?area .\r\n    ?area vitro:mostSpecificType|a|rdfs:label ?areaO .\r\n    ?area ?areaP ?areaO .\r\n  }\r\n  OPTIONAL {\r\n    ?publication vivo:dateIssued ?dateIssued .\r\n    ?dateIssued ?dateIssuedP ?dateIssuedO .\r\n  }\r\n  OPTIONAL {\r\n    ?publication vivo:dateFiled ?dateFiled .\r\n    ?dateFiled ?dateFiledP ?dateFiledO .\r\n  }\r\n}" ;
        :uriBinding             "uri" .

