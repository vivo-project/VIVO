:3ea0fd15-73b7-4cd5-8ba6-3bd004da6398
        a                       <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.ConstructQueryGraphBuilder> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.GraphBuilder> ;
        vitro:mostSpecificType  <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.ConstructQueryGraphBuilder> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.GraphBuilder> ;
        :builderName            "OAI PMH Funding" ;
        :constructQuery         "PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\r\nPREFIX bibo: <http://purl.org/ontology/bibo/>\r\nPREFIX vitro: <http://vitro.mannlib.cornell.edu/ns/vitro/0.7#>\r\nPREFIX bib: <http://zeitkunst.org/bibtex/0.1/bibtex.owl#>\r\nPREFIX obo: <http://purl.obolibrary.org/obo/>\r\nPREFIX vivo: <http://vivoweb.org/ontology/core#>\r\nPREFIX foaf: <http://xmlns.com/foaf/0.1/>\r\nPREFIX ev: <http://www.w3.org/2001/xml-events/>\r\nPREFIX event: <http://purl.org/NET/c4dm/event.owl#>\r\nCONSTRUCT {\r\n  ?uri rdfs:comment \"OpenAIRE Funding\" .\r\n  ?funding ?p ?o .\r\n  ?funding vivo:hasSubjectArea ?subjArea .\r\n  ?subjArea vivo:hasAssociatedConcept ?concept .\r\n  ?concept rdfs:label ?conceptLabel .\r\n  ?funding obo:BFO_0000050 ?ofFunding .\r\n  ?ofFunding a ?ofFundingType .\r\n  ?ofFunding vitro:mostSpecificType ?ofFundingMst .\r\n  ?ofFunding rdfs:label ?ofFundingLabel .\r\n  ?funding vivo:dateTimeInterval ?dti .\r\n  ?dti vivo:end ?dtiEnd .\r\n  ?dtiEnd vivo:dateTime ?dtiEndValue .\r\n  ?dtiEnd vivo:dateTimePrecision ?dtiEndPrecision .\r\n  ?dti vivo:start ?dtiStart .\r\n  ?dtiStart vivo:dateTime ?dtiStartValue .\r\n  ?dtiStart vivo:dateTimePrecision ?dtiStartPrecision .\r\n  ?funding vivo:sponsoredBy ?sponsor .\r\n  ?sponsor a foaf:Organization .\r\n  ?sponsor rdfs:label ?sponsorLabel .\r\n  ?funding vivo:assignedBy ?funder .\r\n  ?funder a foaf:Organization .\r\n  ?funder rdfs:label ?funderLabel .\r\n  ?greaterFunding obo:BFO_0000050 ?funding .\r\n} WHERE {\r\n  {\r\n    ?uri a vivo:Grant .\r\n  }\r\n  UNION\r\n  {\r\n    ?uri a vivo:Award .\r\n  }\r\n  ?uri obo:BFO_0000050* ?funding .\r\n  \r\n  ?funding rdfs:label|vitro:mostSpecificType|a|vivo:totalAwardAmount|bibo:abstract ?o .\r\n  ?funding ?p ?o .\r\n  OPTIONAL { ?greaterFunding obo:BFO_0000050 ?funding .}\r\n  OPTIONAL {\r\n    ?funding vivo:sponsoredBy ?sponsor .\r\n    ?sponsor a foaf:Organization .\r\n    ?sponsor rdfs:label ?sponsorLabel .\r\n  }\r\n  OPTIONAL {\r\n    ?funding vivo:assignedBy ?funder .\r\n    ?funder a foaf:Organization .\r\n    ?funder rdfs:label ?funderLabel .\r\n  }\r\n  OPTIONAL {\r\n    ?funding vivo:hasSubjectArea ?subjArea .\r\n    ?subjArea vivo:hasAssociatedConcept ?concept .\r\n    ?concept rdfs:label ?conceptLabel .\r\n  }\r\n  OPTIONAL {\r\n    ?funding obo:BFO_0000050 ?ofFunding .\r\n    ?ofFunding a bibo:Grant .\r\n    ?ofFunding a ?ofFundingType .\r\n    ?ofFunding vitro:mostSpecificType ?ofFundingMst .\r\n    ?ofFunding rdfs:label ?ofFundingLabel .\r\n  }\r\n  OPTIONAL {\r\n    ?funding vivo:dateTimeInterval ?dti .\r\n    {\r\n      ?dti vivo:end ?dtiEnd .\r\n      ?dtiEnd vivo:dateTime ?dtiEndValue .\r\n      ?dtiEnd vivo:dateTimePrecision ?dtiEndPrecision .\r\n    } \r\n    UNION\r\n    {\r\n      ?dti vivo:start ?dtiStart .\r\n      ?dtiStart vivo:dateTime ?dtiStartValue .\r\n      ?dtiStart vivo:dateTimePrecision ?dtiStartPrecision .\r\n    }\r\n  }\r\n}" ;
        :uriBinding             "uri" .

:9c3ce7a2-47c3-4af9-9483-5578d41ffb18
        a                       <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.ConstructQueryGraphBuilder> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.GraphBuilder> ;
        vitro:mostSpecificType  <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.ConstructQueryGraphBuilder> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.GraphBuilder> ;
        :builderName            "OAI PMH Person" ;
        :constructQuery         "PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\r\nPREFIX vitro: <http://vitro.mannlib.cornell.edu/ns/vitro/0.7#>\r\nPREFIX foaf: <http://xmlns.com/foaf/0.1/>\r\nPREFIX obo: <http://purl.obolibrary.org/obo/>\r\nPREFIX vcard: <http://www.w3.org/2006/vcard/ns#>\r\nPREFIX vivo: <http://vivoweb.org/ontology/core#>\r\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\r\nCONSTRUCT {\r\n ?person ?personProperty ?personObject .\r\n  ?person rdfs:comment \"OpenAIRE Person\" .\r\n  ?person obo:ARG_2000028 ?vcardInd .\r\n  ?vcardInd vcard:hasName ?vcardName .\r\n  ?vcardName vcard:givenName ?givenName .\r\n  ?vcardName vcard:familyName ?familyName .\r\n  ?vcardName vivo:middleName ?middleName .\r\n  ?vcardInd vcard:hasEmail ?emailInd .\r\n  ?emailInd vitro:mostSpecificType ?emailMst .\r\n  ?emailInd vcard:email ?email .\r\n  ?vcardInd vcard:hasTelephone ?telephoneInd .\r\n  ?telephoneInd vitro:mostSpecificType ?telephoneMst .\r\n  ?telephoneInd vcard:telephone ?telephone .\r\n  ?person obo:RO_0000053 ?role .\r\n  ?role vitro:mostSpecificType ?roleType .\r\n  ?person obo:RO_0000053 ?role .\r\n  ?role vitro:mostSpecificType ?roleType.\r\n  ?role vivo:roleContributesTo ?org .\r\n  ?org vivo:abbreviation ?abbreviation .\r\n  ?person vivo:orcidId ?orcid .\r\n} WHERE {\r\n  BIND (?uri as ?person)\r\n  ?person rdfs:label|vitro:mostSpecificType|a|vivo:orcidId|vivo:researcherId|vivo:scopusId ?personObject .\r\n  ?person ?personProperty ?personObject .\r\n  OPTIONAL {\r\n    ?person obo:ARG_2000028 ?vcardInd .\r\n    {\r\n      ?vcardInd vcard:hasName ?vcardName .\r\n      {\r\n        ?vcardName vcard:givenName ?givenName .\r\n      } UNION\r\n      {\r\n        ?vcardName vcard:familyName ?familyName .\r\n      } UNION\r\n      {\r\n        ?vcardName vivo:middleName ?middleName .\r\n      }\r\n    } \r\n    UNION\r\n    {\r\n      ?vcardInd vcard:hasEmail ?emailInd .\r\n      ?emailInd vitro:mostSpecificType ?emailMst .\r\n      ?emailInd vcard:email ?email .\r\n    }\r\n    UNION\r\n    {\r\n      ?vcardInd vcard:hasTelephone ?telephoneInd .\r\n      ?telephoneInd vitro:mostSpecificType ?telephoneMst .\r\n      ?telephoneInd vcard:telephone ?telephone .\r\n    }\r\n  }\r\n  OPTIONAL {\r\n    ?person obo:RO_0000053 ?role .\r\n    ?role vitro:mostSpecificType ?roleType.\r\n    ?role vivo:roleContributesTo ?org .\r\n    ?org a foaf:Organization .\r\n    OPTIONAL {\r\n    \t?org vivo:abbreviation ?abbreviation .\r\n    }\r\n  }\r\n}" ;
        :uriBinding             "uri" .

