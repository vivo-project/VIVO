:7e49263f-bb4a-4394-8e13-f4a2b643ec32
        a                       <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.ConstructQueryGraphBuilder> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.GraphBuilder> ;
        vitro:mostSpecificType  <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.ConstructQueryGraphBuilder> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.GraphBuilder> ;
        :builderName            "OAI PMH Projects" ;
        :constructQuery         "PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\r\nPREFIX vivo: <http://vivoweb.org/ontology/core#>\r\nPREFIX vitro: <http://vitro.mannlib.cornell.edu/ns/vitro/0.7#>\r\nPREFIX obo: <http://purl.obolibrary.org/obo/>\r\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\r\nCONSTRUCT {\r\n  ?project rdfs:comment \"OpenAIRE Project\" .\r\n  ?project ?p ?o .\r\n  ?project obo:BFO_0000055 ?role .\r\n  ?role a ?roleType .\r\n  ?role obo:RO_0000052 ?agent .\r\n  ?agent rdfs:label ?agentLabel .\r\n  ?agent rdf:type ?agentType .\r\n}\r\nWHERE {\r\n  BIND (?uri as ?project)\r\n  ?project a vivo:Project .\r\n  ?project rdfs:label|vitro:mostSpecificType|a ?o .\r\n  ?project ?p ?o .\r\n  OPTIONAL {\r\n    ?project obo:BFO_0000055 ?role .\r\n    ?role a ?roleType .\r\n    ?role obo:RO_0000052 ?agent .\r\n    ?agent rdfs:label ?agentLabel .\r\n    ?agent rdf:type ?agentType .\r\n  }\r\n}" ;
        :uriBinding             "uri" .

:7e49263f-bb4a-4394-8e13-f4a2b643ec56
        a                       <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.ConstructQueryGraphBuilder> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.GraphBuilder> ;
        vitro:mostSpecificType  <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.ConstructQueryGraphBuilder> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.GraphBuilder> ;
        :builderName            "OAI PMH Equipment" ;
        :constructQuery         "PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\r\nPREFIX vivo: <http://vivoweb.org/ontology/core#>\r\nPREFIX vitro: <http://vitro.mannlib.cornell.edu/ns/vitro/0.7#>\r\nCONSTRUCT {\r\n  ?equipment rdfs:comment \"OpenAIRE Equipment\" .\r\n  ?equipment ?p ?o .\r\n}\r\nWHERE {\r\n  BIND (?uri as ?equipment)\r\n  ?equipment a vivo:Equipment .\r\n  ?equipment rdfs:label|vitro:mostSpecificType|a ?o .\r\n  ?equipment ?p ?o .\r\n}" ;
        :uriBinding             "uri" .

:17814aa6-8a6d-47ac-a222-a6b02ff0e921
        a                       <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.ConstructQueryGraphBuilder> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.GraphBuilder> ;
        vitro:mostSpecificType  <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.ConstructQueryGraphBuilder> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.graphbuilder.GraphBuilder> ;
        :builderName            "OAI PMH Publication" ;
        :constructQuery         "PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\r\nPREFIX bibo: <http://purl.org/ontology/bibo/>\r\nPREFIX vitro: <http://vitro.mannlib.cornell.edu/ns/vitro/0.7#>\r\nPREFIX bib: <http://zeitkunst.org/bibtex/0.1/bibtex.owl#>\r\nPREFIX vivo: <http://vivoweb.org/ontology/core#>\r\nPREFIX foaf: <http://xmlns.com/foaf/0.1/>\r\nPREFIX obo: <http://purl.obolibrary.org/obo/>\r\nCONSTRUCT {\r\n  ?publication rdfs:comment \"OpenAIRE Publication\" .\r\n  ?publication ?p ?o .\r\n  ?publication vivo:relatedBy ?relBy .\r\n  ?relBy a ?relType .\r\n  ?relBy vivo:relates ?agent .\r\n  ?agent a ?agentType .\r\n  ?agent rdfs:label ?agentLabel .\r\n  ?publication vivo:hasSubjectArea ?area .\r\n  ?area ?areaP ?areaO .\r\n  ?publication vivo:publisher ?publisher .\r\n  ?publisher a ?publisherType .\r\n  ?publisher rdfs:label ?publisherLabel .\r\n  ?publication vivo:dateTimeValue ?dtv .\r\n  ?dtv ?dtvp ?dtvo .\r\n  ?publication ?publicationToEventProp ?event .\r\n  ?event ?eventProp ?eventValue .\r\n} WHERE {\r\n  BIND (?uri as ?publication)\r\n  {\r\n    ?publication a bibo:Document .\r\n  } UNION\r\n  {\r\n    ?publication a bibo:Journal .\r\n  }\r\n  \r\n  { ?publication a|rdfs:label|vitro:mostSpecificType|bibo:abstract|bibo:issn|bibo:volume|bibo:issue|bibo:pageStart|bibo:pageEnd|bibo:doi|bibo:status|bibo:isbn10|bibo:isbn13|vivo:freetextKeyword|bibo:edition|vivo:placeOfPublication|vivo:abbreviation ?o .\r\n  ?publication ?p ?o .\r\n  }\r\n  UNION\r\n  {\r\n    ?publication vivo:relatedBy ?relBy .\r\n    ?relBy a ?relType .\r\n    ?relBy vivo:relates ?agent .\r\n    ?agent a ?agentType .\r\n    ?agent rdfs:label ?agentLabel .\r\n  }\r\n  UNION\r\n  {\r\n    ?publication vivo:hasSubjectArea ?area .\r\n    ?area vitro:mostSpecificType|a|rdfs:label ?areaO .\r\n    ?area ?areaP ?areaO .\r\n  }\r\n  UNION {\r\n    ?publication vivo:publisher ?publisher .\r\n    ?publisher a foaf:Organization .\r\n    ?publisher a ?publisherType .\r\n    ?publisher rdfs:label ?publisherLabel .\r\n  }\r\n  UNION {\r\n    ?publication vivo:dateTimeValue ?dtv .\r\n    ?dtv ?dtvp ?dtvo .\r\n  }\r\n  UNION {\r\n    ?publication bibo:presentedAt|obo:RO_0002353 ?event .\r\n    ?publication ?publicationToEventProp ?event .\r\n    ?event a|rdfs:label|vivo:abbreviation ?eventValue .\r\n    ?event ?eventProp ?eventValue .\r\n  }\r\n}" ;
        :uriBinding             "uri" .

