:7493e3fe-7368-4068-945f-8d9479fce5f3
        a                       <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.SelectFromContentDistributor> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.DataDistributor> ;
        vitro:mostSpecificType  <java:edu.cornell.library.scholars.webapp.controller.api.distribute.rdf.SelectFromContentDistributor> , <java:edu.cornell.library.scholars.webapp.controller.api.distribute.DataDistributor> ;
        :actionName             "OAI PMH Configuration" ;
        :query                  "PREFIX bob: <http://good.dad/meaning/bob#>\r\nPREFIX bib: <http://zeitkunst.org/bibtex/0.1/bibtex.owl#>\r\nPREFIX bibo: <http://purl.org/ontology/bibo/>\r\nPREFIX fabio: <http://purl.org/spar/fabio/>\r\nPREFIX vivo: <http://vivoweb.org/ontology/core#>\r\nPREFIX obo: <http://purl.obolibrary.org/obo/>\r\nSELECT ?directory ?filter ?lang ?endpoint ?suffix\r\nWHERE {\r\n  {\r\n    BIND (\"publications\" as ?directory)\r\n    BIND (\"type\" as ?filterName)\r\n    BIND (\"OAI PMH Publication\" as ?endpoint)\r\n    BIND (\"\" as ?lang)\r\n    VALUES ?filterValue {\r\n      bibo:Article\r\n      bibo:Book\r\n      bibo:Journal\r\n      bibo:Chapter\r\n      fabio:Comment\r\n      vivo:ConferencePoster\r\n      bibo:Manuscript\r\n      bibo:PersonalCommunicationDocument\r\n      obo:OBI_0000272\r\n      bibo:Report\r\n      vivo:ResearchProposal\r\n      vivo:Speech\r\n      bibo:Thesis\r\n      vivo:WorkingPaper\r\n    }\r\n    BIND (STR(?filterName) + \":\" + STR(?filterValue) as ?filter)\r\n  }\r\n  UNION\r\n  {\r\n    BIND (\"persons\" as ?directory)\r\n    BIND (\"type\" as ?filterName)\r\n    BIND (\"http://xmlns.com/foaf/0.1/Person\" as ?filterValue)\r\n    BIND (\"OAI PMH Person\" as ?endpoint)\r\n    BIND (\"\" as ?lang)\r\n    BIND (STR(?filterName) + \":\" + STR(?filterValue) as ?filter)\r\n  }\r\n  UNION\r\n  {\r\n    BIND (\"orgunits\" as ?directory)\r\n    BIND (\"type\" as ?filterName)\r\n    BIND (\"http://xmlns.com/foaf/0.1/Organization\" as ?filterValue)\r\n    BIND (\"OAI PMH Organization\" as ?endpoint)\r\n    BIND (\"\" as ?lang)\r\n    BIND (STR(?filterName) + \":\" + STR(?filterValue) as ?filter)\r\n  }\r\n  UNION\r\n  {\r\n    BIND (\"events\" as ?directory)\r\n    BIND (\"type\" as ?filterName)\r\n    BIND (\"http://purl.org/NET/c4dm/event.owl#Event\" as ?filterValue)\r\n    BIND (\"OAI PMH Event\" as ?endpoint)\r\n    BIND (\"\" as ?lang)\r\n    BIND (STR(?filterName) + \":\" + STR(?filterValue) as ?filter)\r\n  }\r\n    UNION\r\n  {\r\n    BIND (\"products\" as ?directory)\r\n    BIND (\"type\" as ?filterName)\r\n    VALUES ?filterValue {\r\n      bibo:AudioVisualDocument\r\n      vivo:CaseStudy\r\n      vivo:Dataset\r\n      bibo:Image\r\n    }\r\n    BIND (\"OAI PMH Product\" as ?endpoint)\r\n    BIND (\"\" as ?lang)\r\n    BIND (STR(?filterName) + \":\" + STR(?filterValue) as ?filter)\r\n  }\r\n      UNION\r\n  {\r\n    BIND (\"patents\" as ?directory)\r\n    BIND (\"type\" as ?filterName)\r\n    BIND (bibo:Patent as ?filterValue)\r\n    BIND (\"OAI PMH Patent\" as ?endpoint)\r\n    BIND (\"\" as ?lang)\r\n    BIND (STR(?filterName) + \":\" + STR(?filterValue) as ?filter)\r\n  }\r\n        UNION\r\n  {\r\n    BIND (\"funding\" as ?directory)\r\n    BIND (\"type\" as ?filterName)\r\n    VALUES ?filterValue {\r\n      vivo:Grant\r\n      vivo:Award\r\n    }\r\n    BIND (\"OAI PMH Funding\" as ?endpoint)\r\n    BIND (\"\" as ?lang)\r\n    BIND (STR(?filterName) + \":\" + STR(?filterValue) as ?filter)\r\n  }\r\n        UNION\r\n  {\r\n    BIND (\"equipment\" as ?directory)\r\n    BIND (\"type\" as ?filterName)\r\n    BIND (vivo:Equipment as ?filterValue)\r\n    BIND (\"OAI PMH Equipment\" as ?endpoint)\r\n    BIND (\"\" as ?lang)\r\n    BIND (STR(?filterName) + \":\" + STR(?filterValue) as ?filter)\r\n  }        UNION\r\n  {\r\n    BIND (\"projects\" as ?directory)\r\n    BIND (\"type\" as ?filterName)\r\n    BIND (vivo:Project as ?filterValue)\r\n    BIND (\"OAI PMH Projects\" as ?endpoint)\r\n    BIND (\"\" as ?lang)\r\n    BIND (STR(?filterName) + \":\" + STR(?filterValue) as ?filter)\r\n  }\r\n}" ;
        :resultFormat           "JSON" .

